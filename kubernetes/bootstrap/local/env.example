# k3d Bootstrap Configuration — Local Development

# === CLUSTER ===
# Name of the k3d cluster
K3D_CLUSTER_NAME=local

# k3s image version (see https://hub.docker.com/r/rancher/k3s/tags)
# Leave empty to use k3d's default
K3S_IMAGE=

# === NETWORKING ===
# Host port mapped to Traefik's HTTP entrypoint (container port 80)
K3D_HTTP_PORT=80

# === RESOURCES ===
# Number of server (control-plane) nodes
K3D_SERVERS=1

# Number of agent (worker) nodes (0 = run workloads on the server node)
K3D_AGENTS=0
