# k3s Bootstrap Configuration — Home Server

# === NETWORKING ===
# Primary LAN IP of the TrueNAS server (used for TLS SANs and kubeconfig)
K3S_SERVER_IP=192.168.1.x

# Dedicated IP for k3s node traffic. TrueNAS uses ports 80/443 on the
# primary IP for its web UI, so k3s must bind to a separate IP alias
# to avoid port conflicts. Create this alias on TrueNAS BEFORE installing k3s:
#   System Settings → Network → Interfaces → select interface → Add Alias
# Example: if your primary IP is 192.168.1.100, add 192.168.1.101 as an alias.
K3S_NODE_IP=192.168.1.x

# Tailscale IP (optional, for remote kubectl access)
K3S_TAILSCALE_IP=

# === STORAGE ===
# k3s data directory (stores containerd images, etcd, etc.)
K3S_DATA_DIR=/opt/k3s
