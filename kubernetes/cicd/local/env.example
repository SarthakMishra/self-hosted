# CI/CD Pipeline Secrets — Local Development
#
# Copy to .env and edit with your values:
#   cp env.example .env
#
# Then run setup-secrets.sh to create the Kubernetes secrets:
#   ./setup-secrets.sh

# === GITHUB WEBHOOK ===
# HMAC secret for validating GitHub webhook payloads.
# Must match the secret configured in your GitHub repo webhook settings.
# Generate with: openssl rand -hex 20
GITHUB_WEBHOOK_SECRET=changeme

# === GIT DEPLOY KEY ===
# SSH private key with write access to the GitOps repo.
# Used by the update-manifests step to push image tag changes.
# Generate with: ssh-keygen -t ed25519 -f deploy_key -N ""
# Then add deploy_key.pub as a Deploy Key (with write access) in
# your GitHub repo settings.
GIT_DEPLOY_KEY_PATH=~/.ssh/deploy_key

# === HARBOR REGISTRY ===
# Credentials for BuildKit to push images to Harbor.
# Default Harbor admin password is "changeme" (set in Helm values).
HARBOR_URL=harbor.k8s.local
HARBOR_USERNAME=admin
HARBOR_PASSWORD=changeme
