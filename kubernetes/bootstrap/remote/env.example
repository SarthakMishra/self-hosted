# k3s Bootstrap Configuration — Remote Server (Hetzner)

# === SERVER ===
# Public IP of the Hetzner VPS
K3S_SERVER_IP=changeme

# Tailscale IP (optional, for kubectl access via VPN)
K3S_TAILSCALE_IP=

# === STORAGE ===
# k3s data directory (stores containerd images, etcd, etc.)
K3S_DATA_DIR=/opt/k3s
