# Arr Stack Configuration

# === PATHS ===
BASE_CONFIG_PATH=/path/to/config
BASE_DATA_PATH=/path/to/data

# === USER/PERMISSIONS ===
PUID_SONARR=1010
PUID_RADARR=1010
PUID_PROWLARR=1010
PUID_QBITTORRENT=1010
PUID_BAZARR=1010
PUID_SEERR=1010
PGID_SHARED=3000

# === TIMEZONE ===
TZ_MAIN=Etc/UTC

# === DOMAINS ===
SONARR_DOMAIN=sonarr.example.com
RADARR_DOMAIN=radarr.example.com
PROWLARR_DOMAIN=prowlarr.example.com
QBITTORRENT_DOMAIN=qbittorrent.example.com
BAZARR_DOMAIN=bazarr.example.com
SEERR_DOMAIN=seerr.example.com
PLEX_DOMAIN=plex.example.com
BITMAGNET_DOMAIN=bitmagnet.example.com

# === VPN (PIA) ===
PIA_USERNAME=changeme
PIA_PASSWORD=changeme
PIA_REGION=
# Your local network CIDR (e.g., 192.168.1.0/24 or 192.168.29.0/24)
# Change this to match YOUR actual LAN network
# Do NOT include Docker bridge networks - they're auto-detected
VPN_LAN_NETWORK=192.168.0.0/16
VPN_PIA_PORT_FORWARD_PERSIST=false
VPN_AUTO_PORT_FORWARD=true

# === QBITTORRENT ===
QBITTORRENT_WEBUI_PORT=8080
LIBTORRENT=v1

# === SEERR ===
SEERR_PORT=5055

# === PLEX ===
PLEX_PORT=32400

# === BITMAGNET ===
BITMAGNET_POSTGRES_PASSWORD=postgres
BITMAGNET_BT_PORT=3334
# Optional: set a TMDB API key to enable rich metadata classification
TMDB_API_KEY=026214ed9dbe76891de499a655be2bc1
