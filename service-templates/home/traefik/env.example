# Traefik (Home) Configuration

# === DOMAIN ===
ROOT_DOMAIN=example.com

# === NETWORK ===
TRAEFIK_LOCAL_IP=192.168.1.x

# === LETSENCRYPT ===
LETSENCRYPT_EMAIL=admin@example.com

# === CLOUDFLARE ===
# Scoped API token: Zone:Zone:Read + Zone:DNS:Edit on your ROOT_DOMAIN's zone
# Get from: https://dash.cloudflare.com/profile/api-tokens -> Create Token
CLOUDFLARE_DNS_API_TOKEN=changeme

# === DASHBOARD ===
TRAEFIK_DEBUG=false
TRAEFIK_API_INSECURE=false

# === LOGGING ===
# Options: DEBUG, INFO, WARN, ERROR
TRAEFIK_LOG_LEVEL=INFO
