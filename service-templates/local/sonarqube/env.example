# SonarQube Configuration

# === DATABASE ===
# PostgreSQL database password for SonarQube
# Generate with: openssl rand -base64 32
DB_PASSWORD=changeme

# === SONARQUBE ===
# SonarQube version (use 'lts-community' for latest LTS Community Edition)
# Other options: 'community', 'developer', 'enterprise', or specific version like '10.7-community'
SONARQUBE_VERSION=community

# Port for SonarQube web interface
SONARQUBE_PORT=9000

# === LOCAL PROJECTS ===
# Path to your local projects directory for analysis
# This directory will be mounted read-only at /projects inside the container
# Example: /home/username/projects or C:/Users/username/projects
PROJECTS_PATH=~/projects

# === USAGE NOTES ===
# After starting SonarQube:
# 1. Access web UI at http://localhost:9000
# 2. Default credentials: admin/admin (you'll be prompted to change)
# 3. Create a project and generate an authentication token
# 4. Use sonar-scanner CLI or IDE plugin to analyze projects
# 5. Your projects are accessible at /projects inside the container
#
# To analyze a project, you can:
# - Install sonar-scanner locally and point it to your project
# - Use docker to run sonar-scanner:
#   docker run --rm --network sonarqube-net \
#     -v ~/projects/myproject:/usr/src \
#     sonarsource/sonar-scanner-cli \
#     -Dsonar.projectKey=myproject \
#     -Dsonar.sources=. \
#     -Dsonar.host.url=http://sonarqube:9000 \
#     -Dsonar.login=YOUR_TOKEN
